=x00u
-----END PGP PUBLIC KEY BLOCK-----`,
};

const cryptoAddresses = [
  {
    id: 'bitcoin',
    name: 'Bitcoin',
    symbol: 'BTC',
    address: 'bc1qhgm26cq6vm8989cgq6xsy79pw2t35lx2meafva',
    explorerUrl: 'https://mempool.space/address/bc1qhgm26cq6vm8989cgq6xsy79pw2t35lx2meafva',
    color: '#f7931a',
    icon: '₿',
  },
  {
    id: 'ethereum',
    name: 'Ethereum',
    symbol: 'ETH',
    address: '0x9457537e11e91686bCF8b2403B23040Fc824E959',
    explorerUrl: 'https://etherscan.io/address/0x9457537e11e91686bCF8b2403B23040Fc824E959',
    color: '#627eea',
    icon: '♦',
  },
  {
    id: 'polygon',
    name: 'Polygon',
    symbol: 'MATIC / POL',
    address: '0x9457537e11e91686bCF8b2403B23040Fc824E959',
    explorerUrl: 'https://polygonscan.com/address/0x9457537e11e91686bCF8b2403B23040Fc824E959',
    color: '#8247e5',
    icon: '⬡',
  },
  {
    id: 'solana',
    name: 'Solana',
    symbol: 'SOL',
    address: 'BiJBspHymReWNoWpaKCNB4BJH2gyN8EBg1CDcZSTCnUj',
    explorerUrl: 'https://solscan.io/account/BiJBspHymReWNoWpaKCNB4BJH2gyN8EBg1CDcZSTCnUj',
    color: '#9945ff',
    icon: '◎',
  },
