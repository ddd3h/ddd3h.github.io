  subkeyAlgorithm: 'Cv25519 [E]',
  armoredKey: `-----BEGIN PGP PUBLIC KEY BLOCK-----

mDMEahwSwBYJKwYBBAHaRw8BAQdAWO0wwn0ASR9aQGXPrOSXAklSnefSNcxb3808
